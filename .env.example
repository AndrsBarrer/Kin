# ── Kin Environment ──────────────────────────────────
# Copy to .env and fill in real values

# PostgreSQL
DATABASE_URL=postgresql://kin_user:kin_pass@localhost:5432/kin_db

# Server
PORT=3001
NODE_ENV=development
FRONTEND_URL=http://localhost:5173

# Magic-link auth
MAGIC_LINK_TTL_MINUTES=15
SESSION_SECRET=replace-with-a-64-char-random-hex

# Email (stub — plug in real SMTP / SendGrid later)
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
EMAIL_FROM=noreply@kin.family
